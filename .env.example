# ======================================
# W杯速報 2026 — 環境変数テンプレート
# ======================================
# このファイルを .env.local にコピーして値を設定してください
#   cp .env.example .env.local

# ------ API-Football ------
# 1. https://www.api-football.com/ でアカウント作成
# 2. ダッシュボードからAPIキーをコピー
# 3. 無料プランで 100 requests/day
API_FOOTBALL_KEY=

# ------ LINE Messaging API ------
# 1. https://developers.line.biz にログイン
# 2. プロバイダー作成 → 新規チャネル「Messaging API」を選択
# 3. チャネル名: 「W杯速報 2026」
# 4. 「Messaging API設定」→「チャネルアクセストークン」を発行
# 5. LINE Official Account Manager で自動応答メッセージをOFFにする
LINE_CHANNEL_ACCESS_TOKEN=

# ------ Cron 認証 ------
# Vercel Cron ジョブの不正アクセス防止用シークレット
# Vercel にデプロイすると自動で CRON_SECRET が設定されます
# ローカルテスト用に任意の文字列を設定可能
CRON_SECRET=

# ------ サイトURL (任意) ------
# LINE 通知の「詳しく見る」ボタンのリンク先
# 未設定時はデフォルト値を使用
SITE_URL=
